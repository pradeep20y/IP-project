# Sepolia RPC URL — get one free from Alchemy, Infura, or QuickNode
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY_HERE

# Private key of the deploying wallet (NEVER commit a real key — use a throwaway funded with Sepolia ETH)
PRIVATE_KEY=0xyour_throwaway_private_key_here

# Optional — for contract verification on Etherscan
ETHERSCAN_API_KEY=your_etherscan_api_key_here
